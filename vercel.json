{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/staff/:path*", "destination": "/api/staff.js" },
    { "source": "/api/staff", "destination": "/api/staff.js" },
    { "source": "/api/attendance/:path*", "destination": "/api/attendance.js" },
    { "source": "/api/attendance", "destination": "/api/attendance.js" },
    { "source": "/api/savings/:path*", "destination": "/api/savings.js" },
    { "source": "/api/savings", "destination": "/api/savings.js" },
    { "source": "/api/loans/:path*", "destination": "/api/loans.js" },
    { "source": "/api/loans", "destination": "/api/loans.js" },
    { "source": "/api/commission/:path*", "destination": "/api/commission.js" },
    { "source": "/api/commission", "destination": "/api/commission.js" },
    { "source": "/api/settings/:path*", "destination": "/api/settings.js" },
    { "source": "/api/settings", "destination": "/api/settings.js" },
    { "source": "/api/audit", "destination": "/api/audit.js" }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  }
}
